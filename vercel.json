{
  "version": 2,
  "functions": {
    "insights.js": { "runtime": "@vercel/node@3.2.0" },
    "analyze.js": { "runtime": "@vercel/node@3.2.0" }
  },
  "routes": [
    { "src": "/api/insights", "dest": "/insights.js" },
    { "src": "/api/analyze", "dest": "/analyze.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
